# 服务配置
PORT=8000
DATABASE_URL="file:./data/data.db"

# JWT 认证
JWT_SECRET=your-jwt-secret-key

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAIL=admin@example.com

# 日志配置
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_MAX_FILE_SIZE=10m
LOG_RETENTION_DAYS=7d

# 工作区配置
WORKSPACES_ROOT=./data/workspaces
WORKSPACE_RETENTION_HOURS=0
AUTO_CLEANUP_WORKSPACE=true

# OpenCode 服务路径映射（容器部署时使用）
# 当 OpenCode 服务运行在宿主机，而 opencode-qa 运行在容器中时配置
# 容器内工作区路径会自动转换为此前缀开头的路径
# 示例：容器内 /app/packages/backend/data/workspaces -> /opt/data/workspaces
# 设置：OPENCODE_WORKSPACE_PATH_PREFIX=/opt/data/workspaces
OPENCODE_WORKSPACE_PATH_PREFIX=
