generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(uuid())
  username    String      @unique
  password    String?
  email       String?     @unique
  displayName String      @map("display_name")
  ssoProvider String?     @map("sso_provider")
  ssoUserId   String?     @map("sso_user_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  sessions    Session[]
  messages    Message[]
  userRoles   UserRole[]
  tokens      UserToken[]

  @@unique([ssoProvider, ssoUserId])
  @@map("users")
}

model Role {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  permissions String
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Bot {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  avatar      String?
  apiUrl      String   @map("api_url")
  apiKey      String?  @map("api_key")
  provider    String
  model       String
  agent       String   @default("plan")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  messages    Message[]

  @@map("bots")
}

model Session {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  title             String
  status            String    @default("active")
  needHuman         Boolean   @default(false) @map("need_human")
  isDeleted         Boolean   @default(false) @map("is_deleted")
  opencodeSessionId String?   @map("opencode_session_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  messages          Message[]
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Message {
  id         String    @id @default(uuid())
  sessionId  String    @map("session_id")
  senderType String    @map("sender_type")
  content    String
  metadata   String?
  createdAt  DateTime  @default(now()) @map("created_at")
  
  userId     String?   @map("user_id")
  botId      String?   @map("bot_id")
  
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot        Bot?      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model UserToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_tokens")
}

model SsoProvider {
  id              String   @id @default(uuid())
  name            String   @unique
  displayName     String
  icon            String?
  iconMimeType    String?  @map("icon_mime_type")
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  type            String   @default("GENERIC")
  authorizeUrl    String   @map("authorize_url")
  tokenUrl        String   @map("token_url")
  userInfoUrl     String?  @map("user_info_url")
  clientId        String?  @map("client_id")
  clientSecret    String?  @map("client_secret")
  appId           String?  @map("app_id")
  appSecret       String?  @map("app_secret")
  scope           String   @default("openid profile email")
  userIdField     String   @default("sub") @map("user_id_field")
  usernameField   String   @default("preferred_username") @map("username_field")
  emailField      String   @default("email") @map("email_field")
  displayNameField String  @default("name") @map("display_name_field")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("sso_providers")
}
