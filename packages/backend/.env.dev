# 服务配置
PORT=8000
DATABASE_URL="file:./data/data.db"

# JWT 认证
JWT_SECRET=opencode-qa-jwt-secret-key-change-in-production

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@opencode-qa.local

# OpenCode 服务器认证
OPENCODE_SERVER_PASSWORD=your-password

# 日志配置
LOG_LEVEL=info
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_MAX_FILE_SIZE=10m
LOG_RETENTION_DAYS=7d

# 数据库备份配置
BACKUP_ENABLED=true
BACKUP_PATH=./data/backups
BACKUP_RETENTION_DAYS=7

# 任务加密配置
TASK_ENCRYPTION_KEY=your-32-character-secret-key-here

# 工作区配置
WORKSPACES_ROOT=./data/workspaces
WORKSPACE_RETENTION_HOURS=24
AUTO_CLEANUP_WORKSPACE=true
