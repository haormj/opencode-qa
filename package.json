{
  "name": "opencode-qa",
  "version": "1.1.7",
  "private": true,
  "description": "Business knowledge Q&A system based on OpenCode",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd packages/backend && npm run dev",
    "dev:frontend": "cd packages/frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd packages/backend && npm run build",
    "build:frontend": "cd packages/frontend && npm run build",
    "start": "cd packages/backend && npm run start",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd packages/backend && npm run test",
    "test:frontend": "cd packages/frontend && npm run test",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "cd packages/backend && npm run test:coverage",
    "test:coverage:frontend": "cd packages/frontend && npm run test:coverage",
    "db:generate": "cd packages/backend && npm run db:generate",
    "db:push": "cd packages/backend && npm run db:push",
    "db:migrate": "cd packages/backend && npm run db:migrate",
    "install:all": "npm install && cd packages/backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
